{
    "name": "rudel/rudel",
    "description": "Subdomain multisite app and sandbox orchestration for WordPress",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/inline0/pitmaster"
        }
    ],
    "require": {
        "php": "^8.2",
        "pitmaster/pitmaster": "^0.2.1"
    },
    "autoload": {
        "psr-4": {
            "Rudel\\": "src/",
            "Rudel\\CLI\\": "cli/"
        }
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration",
        "test:security": "phpunit --testsuite security",
        "stan": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=1G",
        "phpstan": "@stan",
        "cs": "phpcs",
        "cs:fix": "phpcbf"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpstan/phpstan": "^2.1"
    }
}
